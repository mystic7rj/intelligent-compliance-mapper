# Exclude local environment secrets from build context.
.env

# Exclude Git metadata from build context.
.git/

# Exclude Python bytecode caches from build context.
__pycache__/
*.pyc

# Exclude test sources from runtime image context.
tests/
.pytest_cache/

# Exclude local virtual environment from build context.
.venv/

# Exclude packaging metadata directories from build context.
*.egg-info/

# Exclude local SQLite database artifacts from build context.
compliance.db
